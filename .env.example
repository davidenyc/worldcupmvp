# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/gameday_map"

# App
NEXT_PUBLIC_APP_URL="https://gamedaymap.com"

# Map provider: "leaflet" (free) or "mapbox"
NEXT_PUBLIC_MAP_PROVIDER="leaflet"
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Google Places API (for venue data)
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACES_TEXT_SEARCH_URL="https://places.googleapis.com/v1/places:searchText"

# Data source: "mock" | "csv" | "google"
DATA_PROVIDER="mock"
CSV_IMPORT_PATH="./data/imports/venues.csv"

# Auth (future)
CLERK_SECRET_KEY=""
NEXTAUTH_SECRET=""
